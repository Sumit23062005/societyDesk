{
  "info": {
    "name": "Society Maintenance Tracker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "b1e2a4b0-1234-4a5b-9c6d-society0001"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "complaintId", "value": "" },
    { "key": "noticeId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Resident",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\",\n  \"flatNumber\": \"A-101\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"phone\": \"9123456789\",\n  \"flatNumber\": \"A-102\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Complaints - Resident",
      "item": [
        {
          "name": "Create Complaint",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/complaints",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Water leakage in bathroom", "type": "text" },
                { "key": "category", "value": "Water", "type": "text" },
                { "key": "description", "value": "There is continuous water leakage near the pipeline.", "type": "text" },
                { "key": "priority", "value": "High", "type": "text" },
                { "key": "photo", "type": "file", "src": [] }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('complaintId', data.data.complaint._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Complaints",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/complaints/my"
          }
        },
        {
          "name": "Get Complaint By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/complaints/{{complaintId}}"
          }
        },
        {
          "name": "Get Complaint History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/complaints/{{complaintId}}/history"
          }
        }
      ]
    },
    {
      "name": "Complaints - Admin",
      "item": [
        {
          "name": "Get All Complaints",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/complaints?status=Open&sort=newest&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["complaints"],
              "query": [
                { "key": "status", "value": "Open" },
                { "key": "sort", "value": "newest" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/complaints/{{complaintId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"In Progress\",\n  \"note\": \"Technician assigned\"\n}"
            }
          }
        },
        {
          "name": "Update Priority",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/complaints/{{complaintId}}/priority",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"priority\": \"High\"\n}"
            }
          }
        },
        {
          "name": "Add Note",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/complaints/{{complaintId}}/notes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Follow-up scheduled for tomorrow\"\n}"
            }
          }
        },
        {
          "name": "Delete Complaint",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/complaints/{{complaintId}}"
          }
        }
      ]
    },
    {
      "name": "Notices",
      "item": [
        {
          "name": "Get All Notices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/notices"
          }
        },
        {
          "name": "Get Notice By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/notices/{{noticeId}}"
          }
        },
        {
          "name": "Create Notice (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/notices",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Water Supply Maintenance\",\n  \"description\": \"Water supply will be interrupted on Sunday from 10 AM to 2 PM.\",\n  \"important\": true,\n  \"pinned\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('noticeId', data.data.notice._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Notice (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/notices/{{noticeId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated: Water supply will resume by 3 PM.\"\n}"
            }
          }
        },
        {
          "name": "Pin/Unpin Notice (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/notices/{{noticeId}}/pin",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pinned\": true\n}"
            }
          }
        },
        {
          "name": "Delete Notice (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/notices/{{noticeId}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard/admin"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    }
  ]
}
